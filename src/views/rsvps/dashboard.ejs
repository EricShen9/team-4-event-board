<section class="glass-panel">
  <h1>My RSVPs</h1>

  <section id="upcoming-rsvps">
    <h2>Upcoming</h2>
    <% if (dashboard.upcoming.length === 0) { %>
      <p>No upcoming RSVPs.</p>
    <% } %>

    <% dashboard.upcoming.forEach(({ event, rsvp }) => { %>
      <div id="rsvp-row-<%= rsvp.id %>" class="entry-card">
        <h3><%= event.title %></h3>
        <p><strong>RSVP status:</strong> <%= rsvp.status %></p>
        <p><strong>Category:</strong> <%= event.category %></p>
        <p><strong>Location:</strong> <%= event.location %></p>
        <p><strong>Starts:</strong> <%= new Date(event.startDateTime).toLocaleString() %></p>

        <form
          hx-post="/events/<%= event.id %>/rsvp"
          hx-target="#rsvp-row-<%= rsvp.id %>"
          hx-swap="outerHTML"
        >
          <button type="submit">Cancel RSVP</button>
        </form>
      </div>
    <% }) %>
  </section>

  <section id="past-rsvps">
    <h2>Past / Cancelled</h2>
    <% if (dashboard.past.length === 0) { %>
      <p>No past or cancelled RSVPs.</p>
    <% } %>

    <% dashboard.past.forEach(({ event, rsvp }) => { %>
      <div class="entry-card">
        <h3><%= event.title %></h3>
        <p><strong>RSVP status:</strong> <%= rsvp.status %></p>
        <p><strong>Event status:</strong> <%= event.status %></p>
        <p><strong>Category:</strong> <%= event.category %></p>
        <p><strong>Location:</strong> <%= event.location %></p>
        <p><strong>Starts:</strong> <%= new Date(event.startDateTime).toLocaleString() %></p>
      </div>
    <% }) %>
  </section>
</section>