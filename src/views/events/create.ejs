<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-3">Create Event</h1>
  <p class="text-slate-500">
    Fill in the details below to create a new event. Required fields are marked
    with <span class="text-red-500">*</span>.
  </p>
  <% if (session.authenticatedUser) { %>
    <p class="text-slate-500 mt-2 mb-0">
      Creating as
      <strong class="text-slate-700"><%= session.authenticatedUser.displayName %></strong>
      (<%= session.authenticatedUser.role %>).
    </p>
  <% } %>
</section>

<section class="max-w-3xl p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <div class="mb-4">
    <h2 class="text-xl font-semibold mb-2">Event Details</h2>
    <p class="text-slate-500">
      New events are created in <strong>draft</strong> status and will not be
      visible to members until published.
    </p>
  </div>

  <form
    class="grid gap-4"
    method="post"
    action="/events"
    hx-post="/events"
    hx-target="#form-status"
    hx-select="#form-status"
    hx-swap="outerHTML"
  >
    <div>
      <label for="title" class="block text-sm font-medium mb-1">
        Title <span class="text-red-500">*</span>
      </label>
      <input
        id="title"
        name="title"
        type="text"
        required
        placeholder="e.g. Annual Company Picnic"
        class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
      />
    </div>

    <div>
      <label for="description" class="block text-sm font-medium mb-1">Description</label>
      <textarea
        id="description"
        name="description"
        rows="3"
        placeholder="Describe what the event is about…"
        class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500 resize-y"
      ></textarea>
    </div>

    <div>
      <label for="location" class="block text-sm font-medium mb-1">Location</label>
      <input
        id="location"
        name="location"
        type="text"
        placeholder="e.g. Main Hall, Room 204, Online"
        class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
      />
    </div>

    <div>
      <label for="category" class="block text-sm font-medium mb-1">Category</label>
      <input
        id="category"
        name="category"
        type="text"
        placeholder="e.g. Workshop, Social, Meeting"
        class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
      />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for="startDateTime" class="block text-sm font-medium mb-1">
          Start Date &amp; Time <span class="text-red-500">*</span>
        </label>
        <input
          id="startDateTime"
          name="startDateTime"
          type="datetime-local"
          required
          class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
        />
      </div>
      <div>
        <label for="endDateTime" class="block text-sm font-medium mb-1">
          End Date &amp; Time <span class="text-red-500">*</span>
        </label>
        <input
          id="endDateTime"
          name="endDateTime"
          type="datetime-local"
          required
          class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
        />
      </div>
    </div>

    <div>
      <label for="capacity" class="block text-sm font-medium mb-1">Capacity</label>
      <input
        id="capacity"
        name="capacity"
        type="number"
        min="1"
        placeholder="Leave blank for unlimited"
        class="w-full px-3 py-2.5 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
      />
      <p class="text-xs text-slate-400 mt-1">Optional. Must be a positive number if provided.</p>
    </div>

    <button
      type="submit"
      class="mt-1 px-4 py-2.5 rounded-lg bg-blue-600 text-white font-medium cursor-pointer hover:bg-blue-700"
    >
      Create Event
    </button>
  </form>
</section>

<!-- ── Status blurb — updated in-place by HTMX after submission ── -->
<div id="form-status" class="max-w-3xl mt-5">
  <% if (pageError) { %>
    <div class="p-4 rounded-xl bg-red-50 border border-red-200 text-red-700 font-medium">
      <span class="mr-1">✗</span> <%= pageError %>
    </div>
  <% } %>
</div>

<script>
  // ── HTMX swap handler for the create-event form ──────────────────
  // By default HTMX does not swap on 4xx responses. This listener
  // forces the swap so the server-rendered error appears, and injects
  // a success banner when the controller redirects (2xx after 302).
  document.body.addEventListener('htmx:beforeSwap', function (evt) {
    if (!evt.detail.target || evt.detail.target.id !== 'form-status') return;

    var status = evt.detail.xhr.status;

    if (status >= 200 && status < 300) {
      // Controller redirected on success — the followed redirect page
      // won't contain #form-status, so we inject a success message and
      // navigate after a short delay.
      evt.detail.shouldSwap  = true;
      evt.detail.serverResponse =
        '<div id="form-status" class="max-w-3xl mt-5">' +
          '<div class="p-4 rounded-xl bg-green-50 border border-green-200 text-green-800 font-medium">' +
            '<span class="mr-1">✓</span> Event created successfully! Redirecting\u2026' +
          '</div>' +
        '</div>';
      setTimeout(function () { window.location.href = '/home'; }, 1500);
    } else if (status >= 400) {
      // Validation or auth error — allow swap so the server-rendered
      // pageError inside #form-status is shown to the user.
      evt.detail.shouldSwap = true;
    }
  });
</script>