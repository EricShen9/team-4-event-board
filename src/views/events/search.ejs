<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-3">Search Events</h1>
  <p class="text-slate-500">
    Search published upcoming events by title, description, or location.
  </p>
</section>

<% if (pageError) { %>
  <%- include("../partials/error", { message: pageError }) %>
<% } %>

<section class="max-w-4xl p-6 border border-slate-200 rounded-2xl bg-white shadow-lg mb-5">
  <form method="get" action="/events/search" class="flex flex-col sm:flex-row gap-3">
    <input
      type="text"
      name="q"
      value="<%= query %>"
      placeholder="Search by title, description, or location"
      class="flex-1 px-3 py-2.5 border border-slate-300 rounded-xl bg-white focus:outline-2 focus:outline-blue-500/20 focus:border-blue-500"
    />
    <button
      type="submit"
      class="px-4 py-2.5 rounded-lg bg-blue-600 text-white font-medium cursor-pointer hover:bg-blue-700"
    >
      Search
    </button>
  </form>
</section>

<section class="max-w-4xl p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <div class="mb-4">
    <h2 class="text-xl font-semibold mb-2">Results</h2>
    <p class="text-slate-500">
      <% if (query && query.trim()) { %>
        Showing results for "<strong><%= query %></strong>"
      <% } else { %>
        Showing all published upcoming events.
      <% } %>
    </p>
  </div>

  <% if (!events || events.length === 0) { %>
    <p class="text-slate-500 mb-0">No matching events found.</p>
  <% } else { %>
    <ul class="list-none m-0 p-0 grid gap-4">
      <% events.forEach((event) => { %>
        <li class="p-4 border border-slate-200 rounded-xl bg-slate-50">
          <h3 class="text-lg font-semibold text-slate-900 mb-1"><%= event.title %></h3>
          <p class="text-sm text-slate-500 mb-1"><%= event.description %></p>
          <p class="text-sm text-slate-600 mb-0">
            <strong>Location:</strong> <%= event.location %>
          </p>
          <p class="text-sm text-slate-600 mb-0">
            <strong>Category:</strong> <%= event.category %>
          </p>
          <p class="text-sm text-slate-600 mb-0">
            <strong>Starts:</strong> <%= new Date(event.startDateTime).toLocaleString() %>
          </p>
        </li>
      <% }) %>
    </ul>
  <% } %>
</section>