<section class="mb-6 overflow-hidden rounded-3xl border border-blue-100 bg-white shadow-xl">
  <div class="grid gap-0 lg:grid-cols-[1.25fr_0.75fr]">
    <div class="bg-gradient-to-br from-blue-50 via-white to-slate-50 p-6 sm:p-8 lg:p-10">
      <p class="mb-3 text-xs font-bold uppercase tracking-[0.25em] text-blue-700">
        Event Search
      </p>

      <h1 class="mb-4 text-4xl font-black tracking-tight text-slate-950 sm:text-5xl">
        Find events faster
      </h1>

      <p class="max-w-2xl text-base leading-7 text-slate-600 sm:text-lg">
        Search published upcoming events by title, description, or location. Results update automatically as you type.
      </p>
    </div>

    <div class="flex items-center bg-gradient-to-br from-blue-600 to-indigo-700 p-6 text-white sm:p-8 lg:p-10">
      <div>
        <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-blue-100">
          Live Search
        </p>

        <p class="text-3xl font-black sm:text-4xl">
          Type. Filter. Clear.
        </p>

        <p class="mt-3 text-sm leading-6 text-blue-100">
          Built with HTMX debounce and Alpine.js clear-button interactivity.
        </p>
      </div>
    </div>
  </div>
</section>

<% if (pageError) { %>
  <%- include("../partials/error", { message: pageError }) %>
<% } %>

<section
  class="mb-6 max-w-5xl rounded-3xl border border-slate-200 bg-white p-4 shadow-xl sm:p-6 lg:p-7"
  x-data="{ query: '' }"
  x-init="query = $refs.searchInput.value"
>
  <form
    id="event-search-form"
    method="get"
    action="/events/search"
    class="grid gap-4 lg:grid-cols-[1fr_auto]"
  >
    <div>
      <div class="mb-3 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <label
            for="event-search-input"
            class="block text-sm font-bold uppercase tracking-wide text-slate-700"
          >
            Search events
          </label>

          <p class="mt-1 text-sm text-slate-500">
            Search by title, description, or location.
          </p>
        </div>

        <p
          class="text-xs font-semibold text-slate-400"
          x-show="query.length > 0"
          x-transition.opacity.duration.150ms
        >
          <span x-text="query.length"></span> characters typed
        </p>
      </div>

      <div class="relative">
        <input
          id="event-search-input"
          x-ref="searchInput"
          x-model="query"
          x-bind:class="query.length > 0 ? 'border-blue-500 bg-white ring-4 ring-blue-100' : 'border-slate-300 bg-slate-50'"
          type="text"
          name="q"
          value="<%= query %>"
          placeholder="Try robotics, alumni, Campus Center..."
          class="w-full rounded-2xl px-4 py-4 pr-20 text-base font-medium text-slate-900 shadow-sm transition placeholder:text-slate-400 focus:border-blue-500 focus:bg-white focus:outline-none focus:ring-4 focus:ring-blue-100"
          hx-get="/events/search"
          hx-trigger="input changed delay:300ms"
          hx-target="#search-results"
          hx-select="#search-results"
          hx-swap="outerHTML"
          hx-include="#event-search-form"
          hx-push-url="true"
          autocomplete="off"
        />

        <button
          type="button"
          x-show="query.length > 0"
          x-transition.opacity.scale.duration.150ms
          x-on:click="
            query = '';
            $nextTick(() => {
              $refs.searchInput.dispatchEvent(new Event('input', { bubbles: true }));
              $refs.searchInput.focus();
            });
          "
          class="absolute right-3 top-1/2 -translate-y-1/2 rounded-full border border-blue-200 bg-blue-50 px-3 py-1.5 text-xs font-bold text-blue-700 shadow-sm transition hover:bg-blue-100 focus:outline-none focus:ring-4 focus:ring-blue-100"
          aria-label="Clear search"
        >
          Clear
        </button>
      </div>
    </div>

    <button
      type="submit"
      class="rounded-2xl bg-blue-600 px-6 py-4 font-bold text-white shadow-lg transition hover:-translate-y-0.5 hover:bg-blue-700 hover:shadow-xl focus:outline-none focus:ring-4 focus:ring-blue-200 lg:self-end"
    >
      Search
    </button>
  </form>
</section>

<%- include("./partials/search-results", { query, events, pageError }) %>