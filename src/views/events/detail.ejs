<section class="max-w-3xl p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <a href="/events" class="text-blue-700 text-sm no-underline hover:underline mb-4 inline-block">&larr; Back to events</a>

  <%- include("./partials/event-status-controls", { event: event, session: session, actionError: null, actionSuccess: null }) %>

  <h1 class="text-3xl font-bold text-slate-900 mb-2"><%= event.title %></h1>

  <div class="space-y-2 text-slate-600 mb-4">
    <p><strong>Location:</strong> <%= event.location %></p>
    <p><strong>Category:</strong> <%= event.category %></p>
    <p><strong>Start:</strong> <%= new Date(event.startDateTime).toLocaleString() %></p>
    <p><strong>End:</strong> <%= new Date(event.endDateTime).toLocaleString() %></p>
    <% if (event.capacity) { %>
      <p><strong>Capacity:</strong> <%= event.capacity %></p>
    <% } else { %>
      <p><strong>Capacity:</strong> Unlimited</p>
    <% } %>
  </div>

  <div class="border-t border-slate-200 pt-4">
    <h2 class="text-lg font-semibold text-slate-800 mb-2">Description</h2>
    <p class="text-slate-600"><%= event.description %></p>
  </div>

    <% if (event.status === "published") { %>
    <div
      id="rsvp-controls-<%= event.id %>"
      hx-get="/events/<%= event.id %>/rsvp-controls"
      hx-trigger="load"
      hx-swap="outerHTML"
    >
      <div class="border-t border-slate-200 pt-4 mt-4">
        <p class="text-sm text-slate-500 mb-0">Loading RSVP controls...</p>
      </div>
    </div>
  <% } %>
</section>

<% if (pageError) { %>
  <%- include("../partials/error", { message: pageError }) %>
<% } %>