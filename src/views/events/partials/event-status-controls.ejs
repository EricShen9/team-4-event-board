<div id="event-status-controls-<%= event.id %>"
     x-data="{ shown: false }"
     x-init="$nextTick(() => { shown = true })"
>
  <span
    x-show="shown"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0 scale-75"
    x-transition:enter-end="opacity-100 scale-100"
    class="inline-block px-2 py-1 rounded text-xs font-semibold mb-3
      <% if (event.status === 'published') { %> bg-green-100 text-green-800 ring-1 ring-green-300
      <% } else if (event.status === 'draft') { %> bg-yellow-100 text-yellow-800 ring-1 ring-yellow-300
      <% } else if (event.status === 'cancelled') { %> bg-red-100 text-red-800 ring-1 ring-red-300
      <% } else { %> bg-slate-100 text-slate-600 ring-1 ring-slate-300
      <% } %>
    "
  ><%= event.status.toUpperCase() %></span>

  <% if (actionError) { %>
    <div class="mb-3 p-3 rounded-lg border border-red-200 bg-red-50 text-red-800 text-sm" aria-live="polite">
      <strong>Error:</strong> <%= actionError %>
    </div>
  <% } %>

  <% if (actionSuccess) { %>
    <div
      x-data="{ visible: true }"
      x-show="visible"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      x-init="setTimeout(() => visible = false, 5000)"
      class="mb-3 p-3 rounded-lg border border-green-200 bg-green-50 text-green-800 text-sm"
      aria-live="polite"
    >
      <span class="mr-1">✓</span> <%= actionSuccess %>
    </div>
  <% } %>

  <% if (session && session.authenticatedUser) { %>
    <% const isOrganizer = session.authenticatedUser.userId === event.organizerId; %>
    <% const isAdmin = session.authenticatedUser.role === 'admin'; %>

    <% if (event.status === 'draft' && (isOrganizer || isAdmin)) { %>
      <div class="mb-3">
        <button
          hx-post="/events/<%= event.id %>/publish"
          hx-target="#event-status-controls-<%= event.id %>"
          hx-swap="outerHTML"
          class="px-4 py-2 rounded-lg bg-green-600 text-white font-medium hover:bg-green-700 text-sm cursor-pointer transition-colors"
        >
          Publish Event
        </button>
      </div>
    <% } %>

    <% if (event.status === 'published' && (isOrganizer || isAdmin)) { %>
      <div class="mb-3">
        <button
          hx-post="/events/<%= event.id %>/cancel"
          hx-target="#event-status-controls-<%= event.id %>"
          hx-swap="outerHTML"
          hx-confirm="Are you sure you want to cancel this event? This action cannot be undone."
          class="px-4 py-2 rounded-lg bg-red-600 text-white font-medium hover:bg-red-700 text-sm cursor-pointer transition-colors"
        >
          Cancel Event
        </button>
      </div>
    <% } %>
  <% } %>
</div>