<div id="event-status-controls-<%= event.id %>">
  <span class="inline-block px-2 py-1 rounded text-xs font-semibold mb-3
    <% if (event.status === 'published') { %> bg-green-100 text-green-800
    <% } else if (event.status === 'draft') { %> bg-yellow-100 text-yellow-800
    <% } else if (event.status === 'cancelled') { %> bg-red-100 text-red-800
    <% } else { %> bg-slate-100 text-slate-600
    <% } %>
  "><%= event.status.toUpperCase() %></span>

  <% if (actionError) { %>
    <div class="mb-3 p-3 rounded-lg border border-red-200 bg-red-50 text-red-800 text-sm" aria-live="polite">
      <strong>Error:</strong> <%= actionError %>
    </div>
  <% } %>

  <% if (actionSuccess) { %>
    <div class="mb-3 p-3 rounded-lg border border-green-200 bg-green-50 text-green-800 text-sm" aria-live="polite">
      <span class="mr-1">✓</span> <%= actionSuccess %>
    </div>
  <% } %>

  <% if (session && session.authenticatedUser) { %>
    <% const isOrganizer = session.authenticatedUser.userId === event.organizerId; %>
    <% const isAdmin = session.authenticatedUser.role === 'admin'; %>

    <% if (event.status === 'draft' && (isOrganizer || isAdmin)) { %>      <div class="mb-3">
        <button
          hx-post="/events/<%= event.id %>/publish"
          hx-target="#event-status-controls-<%= event.id %>"
          hx-swap="outerHTML"
          class="px-4 py-2 rounded-lg bg-green-600 text-white font-medium hover:bg-green-700 text-sm cursor-pointer"
        >
          Publish Event
        </button>
      </div>
    <% } %>

    <% if (event.status === 'published' && (isOrganizer || isAdmin)) { %>
      <div class="mb-3">
        <button
          hx-post="/events/<%= event.id %>/cancel"
          hx-target="#event-status-controls-<%= event.id %>"
          hx-swap="outerHTML"
          hx-confirm="Are you sure you want to cancel this event? This action cannot be undone."
          class="px-4 py-2 rounded-lg bg-red-600 text-white font-medium hover:bg-red-700 text-sm cursor-pointer"
        >
          Cancel Event
        </button>
      </div>
    <% } %>
  <% } %>
</div>