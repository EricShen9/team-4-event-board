<%
  const currentStatus = state.currentRSVP ? state.currentRSVP.status : null;
  const isFull =
    typeof state.event.capacity === "number"
      ? state.attendeeCount >= state.event.capacity
      : false;

  let statusText = "Not RSVPed";
  let statusClasses = "bg-slate-100 text-slate-700";

  if (currentStatus === "going") {
    statusText = "Going";
    statusClasses = "bg-green-100 text-green-800";
  } else if (currentStatus === "waitlisted") {
    statusText = "Waitlisted";
    statusClasses = "bg-yellow-100 text-yellow-800";
  } else if (currentStatus === "cancelled") {
    statusText = "Cancelled";
    statusClasses = "bg-slate-100 text-slate-700";
  }

  let buttonText = isFull ? "Join Waitlist" : "RSVP";
  if (currentStatus === "going" || currentStatus === "waitlisted") {
    buttonText = "Cancel RSVP";
  } else if (currentStatus === "cancelled") {
    buttonText = isFull ? "Rejoin Waitlist" : "Rejoin Event";
  }
%>

<div id="rsvp-controls-<%= state.event.id %>" class="border-t border-slate-200 pt-4 mt-4">
  <div class="flex flex-wrap items-center gap-3 mb-3">
    <span class="inline-block px-2 py-1 rounded text-xs font-semibold <%= statusClasses %>">
      <%= statusText %>
    </span>

    <span class="text-sm text-slate-600">
      <% if (typeof state.event.capacity === "number") { %>
        <strong><%= state.attendeeCount %></strong> / <strong><%= state.event.capacity %></strong> attending
      <% } else { %>
        <strong><%= state.attendeeCount %></strong> attending
      <% } %>
    </span>

    <% if (state.waitlistPosition !== null) { %>
      <span class="inline-block px-2 py-1 rounded text-xs font-semibold bg-orange-100 text-orange-800">
        Waitlist position: #<%= state.waitlistPosition %>
      </span>
    <% } %>
  </div>

  <% if (actionError) { %>
    <div class="mb-3 p-3 rounded-lg border border-red-200 bg-red-50 text-red-800 text-sm" aria-live="polite">
      <strong>Error:</strong> <%= actionError %>
    </div>
  <% } %>

  <% if (actionSuccess) { %>
    <div class="mb-3 p-3 rounded-lg border border-green-200 bg-green-50 text-green-800 text-sm" aria-live="polite">
      <span class="mr-1">✓</span> <%= actionSuccess %>
    </div>
  <% } %>

  <% if (session.authenticatedUser.role !== "user") { %>
    <p class="text-sm text-slate-500 mb-0">
      Organizers and admins cannot RSVP to events.
    </p>
  <% } else if (!state.canInteract) { %>
    <p class="text-sm text-slate-500 mb-0">
      RSVP is unavailable for this event.
    </p>
  <% } else { %>
    <button
      hx-post="/events/<%= state.event.id %>/rsvp"
      hx-target="#rsvp-controls-<%= state.event.id %>"
      hx-swap="outerHTML"
      class="px-4 py-2 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 text-sm cursor-pointer"
    >
      <%= buttonText %>
    </button>
  <% } %>
</div>