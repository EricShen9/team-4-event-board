<section class="max-w-3xl mb-5 p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-4">Events</h1>

  <!-- Filter bar with HTMX -->
  <form
    hx-get="/events"
    hx-target="#event-list"
    hx-swap="outerHTML"
    hx-push-url="true"
    class="flex flex-wrap gap-3 mb-6"
  >
    <select name="category" class="px-3 py-2 rounded-lg border border-slate-200 text-sm">
      <option value="">All Categories</option>
      <option value="social" <%= filters.category === 'social' ? 'selected' : '' %>>Social</option>
      <option value="educational" <%= filters.category === 'educational' ? 'selected' : '' %>>Educational</option>
      <option value="volunteer" <%= filters.category === 'volunteer' ? 'selected' : '' %>>Volunteer</option>
      <option value="sports" <%= filters.category === 'sports' ? 'selected' : '' %>>Sports</option>
      <option value="arts" <%= filters.category === 'arts' ? 'selected' : '' %>>Arts</option>
    </select>

    <select name="timeframe" class="px-3 py-2 rounded-lg border border-slate-200 text-sm">
      <option value="">All Upcoming</option>
      <option value="upcoming" <%= filters.timeframe === 'upcoming' ? 'selected' : '' %>>Upcoming</option>
      <option value="this_week" <%= filters.timeframe === 'this_week' ? 'selected' : '' %>>This Week</option>
      <option value="this_weekend" <%= filters.timeframe === 'this_weekend' ? 'selected' : '' %>>This Weekend</option>
    </select>

    <button type="submit" class="px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium cursor-pointer hover:bg-blue-700">
      Filter
    </button>

    <% if (filters.category || filters.timeframe) { %>
      <a href="/events" class="px-4 py-2 rounded-lg border border-slate-200 text-sm text-slate-600 no-underline hover:bg-slate-50">
        Clear
      </a>
    <% } %>
  </form>

  <%- include("./partials/event-list", { events, pageError }) %>
</section>