<section class="max-w-3xl mb-5 p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-4">Events</h1>

  <!-- Filter bar (updated with HTMX and Alpine.js) -->
  <form
    hx-get="/events"
    hx-target="#event-list"
    hx-swap="outerHTML"
    hx-push-url="true"
    class="flex flex-wrap gap-3 mb-6"
    x-data="{
      category: '<%= filters.category || '' %>',
      timeframe: '<%= filters.timeframe || '' %>',
      get hasFilters() { return this.category !== '' || this.timeframe !== ''; }
    }"
  >
    <select name="category" x-model="category" class="px-3 py-2 rounded-lg border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      <option value="">All Categories</option>
      <option value="social">Social</option>
      <option value="educational">Educational</option>
      <option value="volunteer">Volunteer</option>
      <option value="sports">Sports</option>
      <option value="arts">Arts</option>
    </select>
    <select name="timeframe" x-model="timeframe" class="px-3 py-2 rounded-lg border border-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      <option value="">All Upcoming</option>
      <option value="upcoming">Upcoming</option>
      <option value="this_week">This Week</option>
      <option value="this_weekend">This Weekend</option>
    </select>

    <button type="submit" class="px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium cursor-pointer hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
      Filter
    </button>

    <a
      href="/events"
      x-show="hasFilters"
      x-transition
      class="px-4 py-2 rounded-lg border border-slate-200 text-sm text-slate-600 no-underline hover:bg-slate-50"
    >
      Clear
    </a>
  </form>

  <%- include("./partials/event-list", { events, pageError }) %>
</section>