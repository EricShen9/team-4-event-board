generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// TODO: Define your project's data models here.
// Example:
//
model Event {
  id            String   @id @default(cuid())
  organizerId   String
  title         String
  description   String
  location      String
  category      String
  status        String   // "published", "draft", "cancelled", "past"
  startDateTime DateTime
  endDateTime   DateTime
  capacity      Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([organizerId])
  @@index([status])
  @@index([startDateTime])
}
