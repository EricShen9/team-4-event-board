generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Event {
  id            Int      @id @default(autoincrement())
  organizerId   String
  title         String
  description   String
  location      String
  category      String
  status        String
  startDateTime String
  endDateTime   String
  capacity      Int?
  createdAt     String
  updatedAt     String?

  @@index([organizerId])
  @@index([status])
  @@index([startDateTime])
}