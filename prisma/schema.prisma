generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Event {
  id            Int      @id @default(autoincrement())
  organizerId   String
  title         String
  description   String
  location      String
  category      String
  status        String
  startDateTime String
  endDateTime   String
  capacity      Int?
  createdAt     String
  updatedAt     String?

  rsvps         Rsvp[]

  @@index([organizerId])
  @@index([status])
  @@index([startDateTime])
}

model Rsvp {
  id        String @id
  eventId   Int
  userId    String
  status    String
  createdAt String

  event     Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}